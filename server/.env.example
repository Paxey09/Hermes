# Copy this to .env.local and fill in your actual values
# DO NOT commit .env.local to git

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase Database
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Zoom API (OAuth Server-to-Server)
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_USER_EMAIL=your_zoom_email@gmail.com

# Google Calendar API
GOOGLE_CLIENT_EMAIL=calendar-bot@PROJECT.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_ID=your_calendar_email@gmail.com
GOOGLE_MEET_LINK=https://meet.google.com/xxx-xxxx-xxx

# Email (Gmail SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Groq AI API (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
