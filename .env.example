# Hermes Enterprise Portal - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to version control!

# =============================================================================
# Supabase Configuration (Required)
# =============================================================================

# Client-side Supabase URL (Public)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Client-side Supabase Anon Key (Public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Supabase Service Role Key (Private - Keep Secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT Secret (For custom JWT validation)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# =============================================================================
# Application Configuration
# =============================================================================

# Environment (development, production, test)
NODE_ENV=development

# Server Port
PORT=5000

# Client Port (Development)
CLIENT_PORT=5173

# Application URL
APP_URL=http://localhost:5173
API_URL=http://localhost:5000

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Secret for custom tokens (generate strong random string)
JWT_SECRET=your-jwt-secret-minimum-32-characters

# Session Secret (generate strong random string)
SESSION_SECRET=your-session-secret-minimum-32-characters

# Bcrypt Salt Rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Email Configuration (Optional - for custom SMTP)
# =============================================================================

# SMTP Host (e.g., smtp.gmail.com)
SMTP_HOST=

# SMTP Port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP User
SMTP_USER=

# SMTP Password (use App Password for Gmail)
SMTP_PASS=

# From Email Address
FROM_EMAIL=noreply@exponify.ph
FROM_NAME=Exponify PH

# =============================================================================
# Feature Flags (Optional)
# =============================================================================

# Enable Email Verification
ENABLE_EMAIL_VERIFICATION=true

# Enable 2FA for Admins
ENABLE_2FA=true

# Enable Audit Logging
ENABLE_AUDIT_LOG=true

# Enable Debug Mode (Development only)
DEBUG=false

# =============================================================================
# Third-Party Integrations (Optional)
# =============================================================================

# Google Analytics
VITE_GA_TRACKING_ID=

# Sentry DSN (Error Tracking)
VITE_SENTRY_DSN=

# OpenAI API Key (for AI features)
OPENAI_API_KEY=

# =============================================================================
# Groq AI Configuration (Primary AI Backbone)
# =============================================================================

# Groq API Key (Get from https://console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key_here

# AI Provider Configuration
VITE_AI_PROVIDER=groq

# Groq Model Configuration
VITE_GROQ_MODEL_FAST=llama3-8b-8192
VITE_GROQ_MODEL_BALANCED=llama3-70b-8192
VITE_GROQ_MODEL_ANALYTICAL=mixtral-8x7b-32768
VITE_GROQ_MODEL_CREATIVE=llama3-70b-8192

# AI Debug Settings
VITE_ENABLE_AI_DEBUG=false
VITE_AI_REQUEST_TIMEOUT=30000

# =============================================================================
# Database (Only needed for local PostgreSQL, not Supabase)
# =============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/hermes

# =============================================================================
# Deployment (Optional)
# =============================================================================

# Render/Railway/Vercel specific variables
# RENDER_API_KEY=
# VERCEL_TOKEN=
