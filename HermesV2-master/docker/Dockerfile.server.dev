# Development Dockerfile for Node.js server
FROM node:20-alpine

WORKDIR /app

# Install nodemon for hot reload
RUN npm install -g nodemon

# Install dependencies
COPY server/package*.json ./
RUN npm install

# Copy source code
COPY server/ .

# Expose server port
EXPOSE 5000

# Start with nodemon for hot reload
CMD ["nodemon", "server.js"]
